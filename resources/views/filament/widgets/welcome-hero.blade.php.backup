                 x-init="setTimeout(()=>{let t={{ $activeCount }},d=900,s=Date.now(),iv=setInterval(()=>{let p=Math.min((Date.now()-s)/d,1);n=Math.floor((1-Math.pow(1-p,3))*t);if(p>=1){n=t;clearInterval(iv);}},16);},600)"
                 x-text="n">0</div>
            <div class="bh-card-name">Faol</div>
        </div>
    </div>

