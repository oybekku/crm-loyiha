<div style="width:100%">
<style>
@keyframes bh-grow  { from{height:3px} to{height:var(--h)} }
@keyframes bh-fade  { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }
@keyframes bh-count { from{opacity:0;transform:scale(.6)} to{opacity:1;transform:scale(1)} }
@keyframes bh-dot   { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.4);opacity:.6} }
@keyframes bh-neon  {
    0%   { box-shadow: 0 0 6px #3b82f6, 0 0 24px #3b82f640, inset 0 0 6px #3b82f610; border-color: #3b82f6; }
    20%  { box-shadow: 0 0 8px #8b5cf6, 0 0 30px #8b5cf650, inset 0 0 8px #8b5cf615; border-color: #8b5cf6; }
    40%  { box-shadow: 0 0 8px #06b6d4, 0 0 30px #06b6d450, inset 0 0 8px #06b6d415; border-color: #06b6d4; }
    60%  { box-shadow: 0 0 8px #10b981, 0 0 30px #10b98150, inset 0 0 8px #10b98115; border-color: #10b981; }
    80%  { box-shadow: 0 0 8px #f59e0b, 0 0 30px #f59e0b50, inset 0 0 8px #f59e0b15; border-color: #f59e0b; }
    100% { box-shadow: 0 0 6px #3b82f6, 0 0 24px #3b82f640, inset 0 0 6px #3b82f610; border-color: #3b82f6; }
}

.bh-wrap {
    width: 100%;
    background: #ffffff;
    border-radius: 16px;
    border: 1.5px solid #3b82f6;
    overflow: hidden;
    display: block;
    position: relative;
    animation: bh-fade .5s ease both, bh-neon 5s ease-in-out infinite 0.6s;
}
.bh-video-wrap {
    position: absolute;
    top: 0; right: 0;
    width: 45%;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
}
.bh-video-wrap::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 60%; height: 100%;
    background: linear-gradient(to right, #ffffff, transparent);
    z-index: 2;
}
.bh-video-wrap video {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    min-width: 100%; min-height: 100%;
    width: auto; height: auto;
    opacity: 0.22;
    mix-blend-mode: multiply;
}

/* ─── LEFT ─── */
.bh-left {
    padding: 36px 40px 32px;
    display: flex;
    flex-direction: column;
    gap: 0;
}

.bh-top-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 28px;
}

.bh-greeting {
    font-size: 30px;
    font-weight: 800;
    color: #111827;
    line-height: 1.25;
    margin: 0;
    letter-spacing: -.5px;
}
.bh-greeting-blue { color: #3b82f6; }
.bh-greeting-sub {
    font-size: 13px;
    color: #6b7280;
    margin-top: 8px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 8px;
}
.bh-role-badge {
    background: #eff6ff;
    color: #3b82f6;
    border: 1px solid #bfdbfe;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 12px;
}

/* BestHome logo SVG area */
.bh-logo-area {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
}
.bh-logo-text {
    font-size: 12px;
    font-weight: 800;
    color: #3b82f6;
    letter-spacing: .5px;
}

/* Bar chart */
.bh-chart-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #9ca3af;
    text-transform: uppercase;
    margin-bottom: 10px;
}
.bh-bars {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    height: 90px;
}
.bh-bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
}
.bh-bar {
    width: 100%;
    border-radius: 5px 5px 0 0;
    height: var(--h);
    min-height: 3px;
    animation: bh-grow .85s cubic-bezier(.34,1.25,.64,1) both;
    position: relative;
}
.bh-bar-month {
    font-size: 9px;
    font-weight: 600;
    color: #9ca3af;
}
.bh-bar-col--cur .bh-bar-month {
    color: #3b82f6;
    font-weight: 800;
}
/* Y-axis labels */
.bh-chart-yaxis {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 90px;
    margin-right: 6px;
    padding-bottom: 20px;
}
.bh-chart-yaxis span {
    font-size: 9px;
    color: #d1d5db;
    font-weight: 600;
    line-height: 1;
}
.bh-chart-inner {
    display: flex;
    align-items: flex-end;
    gap: 0;
    margin-top: auto;
}

/* ─── RIGHT ─── */
.bh-right {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: #f9fafb;
}

/* Stat cards 2x2 */
.bh-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

.bh-card {
    background: #ffffff;
    border-radius: 14px;
    border: 1.5px solid #e5e7eb;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: box-shadow .2s, transform .15s;
    cursor: default;
}
.bh-card:hover {
    box-shadow: 0 4px 18px rgba(0,0,0,.08);
    transform: translateY(-2px);
}

.bh-card-icon-wrap {
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
}
.bh-card-body {}
.bh-card-num {
    font-size: 26px;
    font-weight: 900;
    color: #111827;
    line-height: 1;
    font-variant-numeric: tabular-nums;
}
.bh-card-name {
    font-size: 11px;
    color: #9ca3af;
    font-weight: 600;
    margin-top: 3px;
}

/* Card color: orange */
.bh-card--o { border-color: #fed7aa; }
.bh-card--o .bh-card-icon-wrap { background: #fff7ed; color: #ea580c; }

/* Card color: green */
.bh-card--g { border-color: #bbf7d0; }
.bh-card--g .bh-card-icon-wrap { background: #f0fdf4; color: #16a34a; }

/* Card color: blue */
.bh-card--b { border-color: #bfdbfe; }
.bh-card--b .bh-card-icon-wrap { background: #eff6ff; color: #2563eb; }

/* Card color: amber */
.bh-card--a { border-color: #fde68a; }
.bh-card--a .bh-card-icon-wrap { background: #fffbeb; color: #d97706; }

/* Recent projects */
.bh-recent-title {
    font-size: 13px;
    font-weight: 700;
    color: #374151;
    margin: 0 0 10px;
}
.bh-proj-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    background: #ffffff;
    border: 1px solid #f3f4f6;
    border-radius: 10px;
    margin-bottom: 7px;
    transition: border-color .15s;
}
.bh-proj-row:last-child { margin-bottom: 0; }
.bh-proj-row:hover { border-color: #e5e7eb; }
.bh-proj-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    animation: bh-dot 2.5s ease-in-out infinite;
}
.bh-proj-info { flex: 1; min-width: 0; }
.bh-proj-name {
    font-size: 12px; font-weight: 700; color: #1f2937;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.bh-proj-owner {
    font-size: 10px; color: #9ca3af;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.bh-proj-badge {
    font-size: 10px; font-weight: 700;
    border-radius: 20px; padding: 2px 10px;
    white-space: nowrap;
}

/* ── Bottom stats ── */
.bh-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 16px;
    margin-top: 16px;
}
.bh-stat {
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 1px 4px rgba(0,0,0,.05), 0 6px 20px rgba(0,0,0,.05);
    padding: 22px 24px 20px;
    position: relative;
    overflow: hidden;
}

.bh-stat-head {
    display: flex; align-items: center; gap: 10px; margin-bottom: 12px;
}
.bh-stat-icon {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.bh-stat--blue   .bh-stat-icon { background: #eff6ff; color: #2563eb; }
.bh-stat--green  .bh-stat-icon { background: #f0fdf4; color: #16a34a; }
.bh-stat--red    .bh-stat-icon { background: #fef2f2; color: #dc2626; }
.bh-stat--purple .bh-stat-icon { background: #f5f3ff; color: #7c3aed; }

.bh-stat-label {
    font-size: 12px; font-weight: 700; color: #6b7280;
    text-transform: uppercase; letter-spacing: .4px;
}
.bh-stat-value {
    font-size: 26px; font-weight: 900; line-height: 1.1;
    white-space: nowrap; font-variant-numeric: tabular-nums;
}
.bh-stat--blue   .bh-stat-value { color: #2563eb; }
.bh-stat--green  .bh-stat-value { color: #16a34a; }
.bh-stat--red    .bh-stat-value { color: #dc2626; }
.bh-stat--purple .bh-stat-value { color: #7c3aed; }

.bh-stat-desc {
    font-size: 11px; color: #9ca3af; margin-top: 6px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.bh-stat-bar-wrap {
    margin-top: 10px; background: #f3f4f6;
    border-radius: 4px; height: 4px; overflow: hidden;
}
.bh-stat-bar {
    height: 100%; border-radius: 4px;
    background: linear-gradient(90deg,#22c55e,#4ade80);
    transition: width 1s ease;
}

/* ── Row 3: mini kartalar + so'nggi loyihalar ── */
.bh-row3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr 1.8fr;
    gap: 16px;
    margin-top: 16px;
}
.bh-row3-recent {
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 1px 4px rgba(0,0,0,.05), 0 6px 20px rgba(0,0,0,.05);
    padding: 18px 20px;
    overflow: hidden;
}

@media(max-width:1100px) {
    .bh-bottom { grid-template-columns: 1fr 1fr; }
    .bh-row3  { grid-template-columns: 1fr 1fr 1fr; }
    .bh-row3-recent { grid-column: 1 / -1; }
}
@media(max-width:700px) {
    .bh-bottom { grid-template-columns: 1fr; }
    .bh-row3  { grid-template-columns: 1fr 1fr; }
}
</style>

